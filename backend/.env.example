# Environment variables for CSCM Backend

# Server configuration
PORT=3000
HOST=localhost
GATEWAY_PORT=8080
NODE_ENV=development

# Database (SQLite by default — DATABASE_URI reserved for future MongoDB)
DATABASE_URI=

# Redis (for pub/sub messaging between services)
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka (optional — for event streaming)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=cscm-backend

# MQTT (optional — for IoT messaging)
MQTT_URL=mqtt://localhost:1883

# Authentication
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRATION=24h

# Python AI/ML API
AI_ML_API_URL=http://localhost:8000
AI_ML_API_TIMEOUT_MS=30000
AI_ML_API_KEY=

# Logging
LOG_LEVEL=info

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100