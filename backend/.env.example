# Environment variables for CSCM Backend

# Server configuration
PORT=3000
HOST=localhost
NODE_ENV=development

# Database
DATABASE_URI=mongodb://localhost:27017/cscm

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=cscm-backend

# MQTT
MQTT_URL=mqtt://localhost:1883

# Authentication
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRATION=24h

# Logging
LOG_LEVEL=info

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100