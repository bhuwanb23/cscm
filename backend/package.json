{
  "name": "cscm-backend",
  "version": "1.0.0",
  "description": "Backend services for Cognitive Supply Chain Mesh",
  "main": "src/api/server.js",
  "scripts": {
    "start": "node src/api/server.js",
    "dev": "nodemon src/api/server.js",
    "test": "jest",
    "test:integration": "node scripts/run_integration_tests.js",
    "lint": "eslint src/**/*.js",
    "postinstall": "node -e \"require('fs').existsSync('.env') || require('fs').copyFileSync('.env.example', '.env')\"",
    "agents": "node src/agents/startAgents.js",
    "verify-agents": "node src/agents/verifyAgents.js",
    "test-redis": "node src/messaging/testRedis.js",
    "check-redis": "node src/messaging/checkRedis.js",
    "test-sqlite": "node src/storage/testSqlite.js",
    "demo-sqlite": "node src/storage/demoSqlite.js",
    "test-features": "node src/features/testFeatures.js",
    "demo-features": "node src/features/demoFeatures.js",
    "test-knowledge-graph": "node src/knowledge-graph/testGraph.js",
    "agent-runtime": "node src/agent-runtime/startRuntime.js",
    "test-agent-runtime": "node src/agent-runtime/testRuntime.js"
  },
  "keywords": [
    "supply-chain",
    "ai",
    "ml",
    "kafka",
    "microservices"
  ],
  "author": "CSCM Team",
  "license": "MIT",
  "dependencies": {
    "@datastructures-js/graph": "^5.3.1",
    "ajv": "^8.17.1",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "helmet": "^6.2.0",
    "http-proxy-middleware": "^2.0.9",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "mqtt": "^4.3.8",
    "prom-client": "^14.2.0",
    "redis": "^4.6.13",
    "sqlite3": "^5.1.7",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "supertest": "^6.3.4"
  }
}
